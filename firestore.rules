rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasUserProfile() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userRole() {
      return userDoc().data.role;
    }

    function userFacilityId() {
      return userDoc().data.facilityId;
    }

    function isStaff() {
      return hasUserProfile() && userRole() == "staff";
    }

    function isManager() {
      return hasUserProfile() && userRole() == "manager";
    }

    function belongsToFacility(facilityId) {
      return hasUserProfile() && userFacilityId() == facilityId;
    }

    function managerForFacility(facilityId) {
      return isManager() && belongsToFacility(facilityId);
    }

    function staffForFacility(facilityId) {
      return isStaff() && belongsToFacility(facilityId);
    }

    function teamForFacility(facilityId) {
      return (isStaff() || isManager()) && belongsToFacility(facilityId);
    }

    function isPublicEquipmentRead() {
      return resource.data.publicVisible == true
        && resource.data.archived != true
        && resource.data.keys().hasOnly([
          "id",
          "facilityId",
          "locationId",
          "publicSlug",
          "publicVisible",
          "publicName",
          "publicImageUrl",
          "publicLocationName",
          "publicStatus",
          "publicStatusCopy",
          "publicManufacturer",
          "publicModel",
          "showLastCleaned",
          "showLastMaintained",
          "showLastInspected",
          "lastCleanedAt",
          "lastMaintainedAt",
          "lastInspectedAt",
          "hasActivePublicFault",
          "outOfOrderMessage",
          "archived"
        ]);
    }

    function isPublicFaultCreate() {
      let publicEquipment = get(/databases/$(database)/documents/publicEquipment/$(request.resource.data.publicSlug));

      return publicEquipment.data.publicVisible == true
        && publicEquipment.data.archived != true
        && publicEquipment.data.facilityId == request.resource.data.facilityId
        && publicEquipment.data.locationId == request.resource.data.locationId
        && publicEquipment.data.equipmentId == request.resource.data.equipmentId
        && request.resource.data.reporterType == "public"
        && request.resource.data.status == "new"
        && request.resource.data.priority == "medium"
        && request.resource.data.keys().hasOnly([
          "id",
          "facilityId",
          "locationId",
          "equipmentId",
          "publicSlug",
          "category",
          "description",
          "photoUrl",
          "contactEmail",
          "reporterType",
          "status",
          "priority",
          "createdAt"
        ]);
    }

    function isPublicFaultStateUpdate() {
      return resource.data.publicVisible == true
        && resource.data.archived != true
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "hasActivePublicFault",
          "publicStatus",
          "publicStatusCopy"
        ])
        && request.resource.data.hasActivePublicFault == true
        && request.resource.data.publicStatus == "amber"
        && request.resource.data.publicStatusCopy == "Use with awareness";
    }

    function isCareSummaryUpdate() {
      return teamForFacility(resource.data.facilityId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "lastCleanedAt",
          "lastMaintainedAt",
          "lastInspectedAt"
        ]);
    }

    function taskEvidenceSatisfied() {
      let equipment = get(/databases/$(database)/documents/equipment/$(resource.data.equipmentId));

      return request.resource.data.status != "completed"
        || resource.data.evidenceLevel == "quick"
        || resource.data.evidenceLevel == "checklist"
          && resource.data.checklistItems.size() > 0
          && request.resource.data.checklistCompleted.hasAll(resource.data.checklistItems)
        || resource.data.evidenceLevel == "qr"
          && request.resource.data.qrConfirmation == equipment.data.publicSlug
        || resource.data.evidenceLevel == "photo_note"
          && request.resource.data.note is string
          && request.resource.data.note.size() > 0
          && request.resource.data.photoUrl is string
          && request.resource.data.photoUrl.size() > 0;
    }

    function staffCanReadTask(taskData) {
      return staffForFacility(taskData.facilityId)
        && (
          !taskData.keys().hasAny(["assignedTo"])
          || taskData.assignedTo == ""
          || taskData.assignedTo == request.auth.uid
        );
    }

    function staffCanCompleteTask() {
      return staffCanReadTask(resource.data)
        && request.resource.data.facilityId == resource.data.facilityId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "status",
          "completedAt",
          "completedBy",
          "checklistCompleted",
          "evidence",
          "note",
          "photoUrl",
          "qrConfirmation",
          "updatedAt"
        ])
        && (
          request.resource.data.status != "completed"
          || request.resource.data.completedBy == request.auth.uid
        )
        && taskEvidenceSatisfied();
    }

    function staffMarksEquipmentOutOfOrder() {
      return teamForFacility(resource.data.facilityId)
        && request.resource.data.facilityId == resource.data.facilityId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "status",
          "updatedAt"
        ])
        && request.resource.data.status == "red";
    }

    function teamMarksPublicEquipmentOutOfOrder() {
      return teamForFacility(resource.data.facilityId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "hasActivePublicFault",
          "outOfOrderMessage",
          "publicStatus",
          "publicStatusCopy"
        ])
        && request.resource.data.hasActivePublicFault == true
        && request.resource.data.publicStatus == "red";
    }

    function managerReturnsPublicEquipmentToService() {
      return managerForFacility(resource.data.facilityId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "hasActivePublicFault",
          "outOfOrderMessage",
          "publicStatus",
          "publicStatusCopy"
        ])
        && request.resource.data.hasActivePublicFault == false
        && request.resource.data.outOfOrderMessage == ""
        && request.resource.data.publicStatus == "green";
    }

    function activityFieldsAreValid() {
      return request.resource.data.keys().hasOnly([
        "id",
        "facilityId",
        "locationId",
        "equipmentId",
        "taskId",
        "issueId",
        "type",
        "title",
        "meta",
        "actorId",
        "actorName",
        "actorRole",
        "managerOnly",
        "createdAt"
      ])
      && request.resource.data.id == request.resource.id
      && request.resource.data.facilityId is string
      && request.resource.data.locationId is string
      && request.resource.data.equipmentId is string
      && request.resource.data.taskId is string
      && request.resource.data.issueId is string
      && request.resource.data.title is string
      && request.resource.data.meta is string
      && request.resource.data.actorId is string
      && request.resource.data.actorName is string
      && request.resource.data.actorRole in ["public", "staff", "manager", "system"]
      && request.resource.data.managerOnly is bool
      && request.resource.data.type in [
        "equipment_created",
        "task_completed",
        "fault_reported",
        "issue_status_changed",
        "equipment_marked_out_of_order",
        "equipment_returned_to_service",
        "spot_check_completed",
        "ai_insight_created"
      ];
    }

    function isPublicFaultActivityCreate() {
      let issue = get(/databases/$(database)/documents/issues/$(request.resource.data.issueId));

      return activityFieldsAreValid()
        && request.resource.data.type == "fault_reported"
        && request.resource.data.actorRole == "public"
        && request.resource.data.actorId == ""
        && request.resource.data.actorName == "Public user"
        && request.resource.data.managerOnly == false
        && request.resource.data.taskId == ""
        && issue.data.reporterType == "public"
        && issue.data.facilityId == request.resource.data.facilityId
        && issue.data.locationId == request.resource.data.locationId
        && issue.data.equipmentId == request.resource.data.equipmentId
        && issue.data.id == request.resource.data.issueId;
    }

    function activityVisibilityIsSafe() {
      return request.resource.data.type != "spot_check_completed"
        || request.resource.data.managerOnly == true;
    }

    function spotCheckFieldsAreValid() {
      return request.resource.data.keys().hasOnly([
        "id",
        "facilityId",
        "locationId",
        "equipmentId",
        "taskId",
        "staffUserId",
        "status",
        "sampleReason",
        "managerNote",
        "reviewedBy",
        "reviewedAt",
        "createdAt",
        "updatedAt"
      ])
      && request.resource.data.id == request.resource.id
      && request.resource.data.status in [
        "pending",
        "passed",
        "failed",
        "recheck_required",
        "escalated"
      ];
    }

    function generatedSpotCheckCreate() {
      let task = get(/databases/$(database)/documents/careTaskInstances/$(request.resource.data.taskId));

      return spotCheckFieldsAreValid()
        && staffForFacility(request.resource.data.facilityId)
        && request.resource.data.status == "pending"
        && request.resource.data.managerNote == ""
        && request.resource.data.reviewedBy == ""
        && request.resource.data.reviewedAt == ""
        && task.data.facilityId == request.resource.data.facilityId
        && task.data.locationId == request.resource.data.locationId
        && task.data.equipmentId == request.resource.data.equipmentId
        && task.data.completedBy == request.auth.uid
        && task.data.status == "completed"
        && request.resource.data.staffUserId == request.auth.uid;
    }

    function samplingStateFieldsAreValid() {
      return request.resource.data.keys().hasOnly([
        "id",
        "facilityId",
        "scope",
        "scopeId",
        "confidence",
        "sampleRate",
        "passedChecks",
        "failedChecks",
        "totalReviewed",
        "explanation",
        "updatedAt"
      ])
      && request.resource.data.id == request.resource.id
      && request.resource.data.scope in ["facility", "location", "staff", "category"]
      && request.resource.data.confidence in ["green", "amber", "red"]
      && request.resource.data.sampleRate is number
      && request.resource.data.sampleRate >= 0.05
      && request.resource.data.sampleRate <= 0.6;
    }

    function replacementReviewFieldsAreValid(reviewId) {
      return request.resource.data.keys().hasOnly([
        "id",
        "equipmentId",
        "facilityId",
        "state",
        "status",
        "score",
        "summary",
        "acknowledgedAt",
        "acknowledgedBy",
        "dismissedAt",
        "dismissedBy",
        "updatedAt"
      ])
      && request.resource.data.id == reviewId
      && request.resource.data.equipmentId == reviewId
      && request.resource.data.facilityId is string
      && request.resource.data.state in ["acknowledged", "dismissed"]
      && request.resource.data.status in [
        "none",
        "watch",
        "review_recommended",
        "high_priority_review"
      ]
      && request.resource.data.score is number
      && request.resource.data.score >= 0
      && request.resource.data.summary is string
      && request.resource.data.acknowledgedAt is string
      && request.resource.data.acknowledgedBy is string
      && request.resource.data.dismissedAt is string
      && request.resource.data.dismissedBy is string
      && request.resource.data.updatedAt is string;
    }

    match /users/{userId} {
      allow create: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.role == "staff"
        && request.resource.data.facilityId is string;

      allow read: if signedIn()
        && (
          request.auth.uid == userId
          || managerForFacility(resource.data.facilityId)
        );

      allow update: if signedIn()
        && (
          request.auth.uid == userId
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["lastLoginAt"])
          || managerForFacility(resource.data.facilityId)
            && request.resource.data.facilityId == resource.data.facilityId
        );

      allow delete: if false;
    }

    match /facilities/{facilityId} {
      allow read: if teamForFacility(facilityId);
      allow create, update: if managerForFacility(facilityId);
      allow delete: if false;
    }

    match /locations/{locationId} {
      allow read: if teamForFacility(resource.data.facilityId);
      allow create: if managerForFacility(request.resource.data.facilityId);
      allow update: if managerForFacility(resource.data.facilityId)
        && request.resource.data.facilityId == resource.data.facilityId
        && request.resource.data.id == resource.data.id
        && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if false;
    }

    match /equipment/{equipmentId} {
      allow read: if teamForFacility(resource.data.facilityId) || isPublicEquipmentRead();
      allow create: if managerForFacility(request.resource.data.facilityId)
        && request.resource.data.keys().hasOnly([
          "id",
          "facilityId",
          "locationId",
          "name",
          "manufacturer",
          "model",
          "equipmentType",
          "equipmentNumber",
          "description",
          "imageUrl",
          "publicSlug",
          "publicVisible",
          "status",
          "archived",
          "createdAt",
          "updatedAt"
        ])
        && request.resource.data.status == "green"
        && request.resource.data.archived == false;
      allow update: if managerForFacility(resource.data.facilityId)
        && request.resource.data.facilityId == resource.data.facilityId
        || staffMarksEquipmentOutOfOrder();
      allow delete: if false;
    }

    match /publicEquipment/{slug} {
      allow get: if true;
      allow list: if false;
      allow create: if managerForFacility(request.resource.data.facilityId)
        && request.resource.data.keys().hasOnly([
          "id",
          "facilityId",
          "locationId",
          "equipmentId",
          "publicSlug",
          "publicVisible",
          "publicName",
          "publicImageUrl",
          "publicLocationName",
          "publicStatus",
          "publicStatusCopy",
          "publicManufacturer",
          "publicModel",
          "showLastCleaned",
          "showLastMaintained",
          "showLastInspected",
          "lastCleanedAt",
          "lastMaintainedAt",
          "lastInspectedAt",
          "hasActivePublicFault",
          "outOfOrderMessage",
          "archived"
        ]);
      allow update: if managerForFacility(request.resource.data.facilityId)
        && request.resource.data.keys().hasOnly([
          "id",
          "facilityId",
          "locationId",
          "equipmentId",
          "publicSlug",
          "publicVisible",
          "publicName",
          "publicImageUrl",
          "publicLocationName",
          "publicStatus",
          "publicStatusCopy",
          "publicManufacturer",
          "publicModel",
          "showLastCleaned",
          "showLastMaintained",
          "showLastInspected",
          "lastCleanedAt",
          "lastMaintainedAt",
          "lastInspectedAt",
          "hasActivePublicFault",
          "outOfOrderMessage",
          "archived"
        ])
        || isPublicFaultStateUpdate()
        || isCareSummaryUpdate()
        || teamMarksPublicEquipmentOutOfOrder()
        || managerReturnsPublicEquipmentToService();
      allow delete: if false;
    }

    match /issues/{issueId} {
      allow create: if isPublicFaultCreate()
        || teamForFacility(request.resource.data.facilityId);
      allow read: if teamForFacility(resource.data.facilityId);
      allow update: if managerForFacility(resource.data.facilityId)
        && request.resource.data.facilityId == resource.data.facilityId
        && request.resource.data.id == resource.data.id
        && request.resource.data.equipmentId == resource.data.equipmentId
        && request.resource.data.locationId == resource.data.locationId
        && request.resource.data.publicSlug == resource.data.publicSlug
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.keys().hasOnly([
          "id",
          "facilityId",
          "locationId",
          "equipmentId",
          "publicSlug",
          "category",
          "description",
          "photoUrl",
          "contactEmail",
          "reporterType",
          "status",
          "priority",
          "createdAt",
          "assignedTo",
          "internalNotes",
          "aiAnalysis",
          "aiAnalyzedAt",
          "aiError",
          "updatedAt",
          "resolvedAt",
          "closedAt"
        ]);
      allow delete: if false;
    }

    match /careTaskSchedules/{scheduleId} {
      allow read: if teamForFacility(resource.data.facilityId);
      allow create: if managerForFacility(request.resource.data.facilityId);
      allow update: if managerForFacility(resource.data.facilityId)
        && request.resource.data.facilityId == resource.data.facilityId;
      allow delete: if false;
    }

    match /careTaskInstances/{taskId} {
      allow read: if managerForFacility(resource.data.facilityId)
        || staffCanReadTask(resource.data);
      allow create: if managerForFacility(request.resource.data.facilityId);
      allow update: if managerForFacility(resource.data.facilityId)
        && request.resource.data.facilityId == resource.data.facilityId
        || staffCanCompleteTask();
      allow delete: if false;
    }

    match /outOfOrderEvents/{eventId} {
      allow read: if teamForFacility(resource.data.facilityId);
      allow create: if teamForFacility(request.resource.data.facilityId)
        && request.resource.data.keys().hasOnly([
          "id",
          "facilityId",
          "locationId",
          "equipmentId",
          "createdBy",
          "reason",
          "severity",
          "photoUrl",
          "unsafe",
          "unavailable",
          "note",
          "linkedIssueId",
          "resolvedAt",
          "returnedToServiceBy",
          "createdAt"
        ]);
      allow update: if managerForFacility(resource.data.facilityId)
        && request.resource.data.facilityId == resource.data.facilityId;
      allow delete: if false;
    }

    match /spotChecks/{spotCheckId} {
      allow read: if managerForFacility(resource.data.facilityId)
        || staffForFacility(resource.data.facilityId)
          && resource.data.staffUserId == request.auth.uid
          && resource.data.status == "recheck_required";
      allow create: if generatedSpotCheckCreate()
        || managerForFacility(request.resource.data.facilityId)
          && spotCheckFieldsAreValid()
          && request.resource.data.reviewedBy != request.resource.data.staffUserId;
      allow update: if managerForFacility(resource.data.facilityId)
        && spotCheckFieldsAreValid()
        && request.resource.data.facilityId == resource.data.facilityId
        && request.resource.data.id == resource.data.id
        && request.resource.data.locationId == resource.data.locationId
        && request.resource.data.equipmentId == resource.data.equipmentId
        && request.resource.data.taskId == resource.data.taskId
        && request.resource.data.staffUserId == resource.data.staffUserId
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.reviewedBy != request.resource.data.staffUserId;
      allow delete: if false;
    }

    match /samplingStates/{stateId} {
      allow read: if managerForFacility(resource.data.facilityId);
      allow create, update: if managerForFacility(request.resource.data.facilityId)
        && samplingStateFieldsAreValid();
      allow delete: if false;
    }

    match /aiInsights/{insightId} {
      allow read: if managerForFacility(resource.data.facilityId);
      allow create: if managerForFacility(request.resource.data.facilityId);
      allow update: if managerForFacility(resource.data.facilityId)
        && request.resource.data.facilityId == resource.data.facilityId;
      allow delete: if false;
    }

    match /replacementReviews/{reviewId} {
      allow read: if managerForFacility(resource.data.facilityId);
      allow create: if managerForFacility(request.resource.data.facilityId)
        && replacementReviewFieldsAreValid(reviewId);
      allow update: if managerForFacility(resource.data.facilityId)
        && request.resource.data.facilityId == resource.data.facilityId
        && replacementReviewFieldsAreValid(reviewId);
      allow delete: if false;
    }

    match /activityFeedItems/{activityId} {
      allow read: if teamForFacility(resource.data.facilityId)
        && (resource.data.managerOnly != true || isManager());
      allow create: if (
          activityFieldsAreValid()
          && teamForFacility(request.resource.data.facilityId)
          && activityVisibilityIsSafe()
        )
        || isPublicFaultActivityCreate();
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
